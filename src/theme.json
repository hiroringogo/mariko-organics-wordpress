{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1200px",
			"wideSize": "1440px"
		},
		"color": {
			"defaultPalette": false,
			"palette": [
				{
					"slug": "background",
					"color": "#FAF8F5",
					"name": "Background"
				},
				{
					"slug": "foreground",
					"color": "#2D2D2D",
					"name": "Foreground"
				},
				{
					"slug": "primary",
					"color": "#7C9082",
					"name": "Primary"
				},
				{
					"slug": "secondary",
					"color": "#E8E4DF",
					"name": "Secondary"
				},
				{
					"slug": "white",
					"color": "#FFFFFF",
					"name": "White"
				},
				{
					"slug": "dark",
					"color": "#2D2D2D",
					"name": "Dark"
				},
				{
					"slug": "text-muted",
					"color": "#8A8A8A",
					"name": "Text Muted"
				},
				{
					"slug": "text-light",
					"color": "#ADADAD",
					"name": "Text Light"
				},
				{
					"slug": "primary-light",
					"color": "#7C908215",
					"name": "Primary Light"
				},
				{
					"slug": "primary-badge",
					"color": "#7C908220",
					"name": "Primary Badge"
				},
				{
					"slug": "gold",
					"color": "#C9A96E",
					"name": "Gold"
				},
				{
					"slug": "amazon-orange",
					"color": "#FF9900",
					"name": "Amazon Orange"
				},
				{
					"slug": "members-hero-dark",
					"color": "#3D534A",
					"name": "Members Hero Dark"
				},
				{
					"slug": "members-hero-mid",
					"color": "#4A6358",
					"name": "Members Hero Mid"
				},
				{
					"slug": "members-hero-light",
					"color": "#5A7368",
					"name": "Members Hero Light"
				},
				{
					"slug": "members-text",
					"color": "#F5F0E8",
					"name": "Members Text"
				},
				{
					"slug": "members-text-muted",
					"color": "#C5CBCA",
					"name": "Members Text Muted"
				}
			]
		},
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "'Fraunces', serif",
					"slug": "heading",
					"name": "Heading",
					"fontFace": [
						{
							"fontFamily": "Fraunces",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": ["https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&display=swap"]
						}
					]
				},
				{
					"fontFamily": "'Inter', sans-serif",
					"slug": "body",
					"name": "Body",
					"fontFace": [
						{
							"fontFamily": "Inter",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": ["https://fonts.googleapis.com/css2?family=Inter:wght@400;500&display=swap"]
						}
					]
				},
				{
					"fontFamily": "'IBM Plex Mono', monospace",
					"slug": "mono",
					"name": "Mono",
					"fontFace": [
						{
							"fontFamily": "IBM Plex Mono",
							"fontWeight": "500",
							"fontStyle": "normal",
							"src": ["https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500&display=swap"]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "12px",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "14px",
					"name": "Medium"
				},
				{
					"slug": "normal",
					"size": "15px",
					"name": "Normal"
				},
				{
					"slug": "large",
					"size": "20px",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "36px",
					"name": "X-Large"
				},
				{
					"slug": "huge",
					"size": "52px",
					"name": "Huge"
				}
			]
		},
		"spacing": {
			"units": ["px", "rem", "%"]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--foreground)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "15px",
			"lineHeight": "1.6"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "0",
				"bottom": "0",
				"left": "0"
			}
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--huge)",
					"fontWeight": "400",
					"letterSpacing": "-1px",
					"lineHeight": "1.2"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "400",
					"letterSpacing": "-0.5px",
					"lineHeight": "1.3"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "400"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--foreground)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--white)"
				},
				"border": {
					"radius": "24px"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "14px",
					"fontWeight": "500"
				},
				"spacing": {
					"padding": {
						"top": "14px",
						"right": "32px",
						"bottom": "14px",
						"left": "32px"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "front-page",
			"title": "Front Page",
			"postTypes": ["page"]
		},
		{
			"name": "page-members",
			"title": "Members Page",
			"postTypes": ["page"]
		}
	]
}
