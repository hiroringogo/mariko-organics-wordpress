                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "Q5rKZ",
                  "name": "articleHeroImg",
                  "clip": true,
                  "width": "fill_container",
                  "height": 400,
                  "fill": {
                    "type": "image",
                    "enabled": true,
                    "url": "./images/generated-1772934298936.png",
                    "mode": "fill"
                  },
                  "cornerRadius": 16
                },
                {
                  "type": "text",
                  "id": "UDmAu",
                  "name": "bodyText1",
                  "fill": "#3D3D3D",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "生米料理を始めてから、キッチンツールにもこだわるようになりました。今回は、私が毎日のお料理で実際に使っている「本当に買ってよかった！」と思えるアイテムをご紹介します。\n\nどれも使い心地がよく、長く愛用できるものばかり。生米料理に限らず、普段のお料理にも活躍してくれますよ。",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 15,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "Wuz9G",
                  "name": "h2_1",
                  "fill": "#2D2D2D",
                  "content": "1. ハイパワーブレンダー",
                  "fontFamily": "Fraunces",
                  "fontSize": 24,
                  "fontWeight": "normal",
                  "letterSpacing": -0.3
                },
                {
                  "type": "text",
                  "id": "bInkX",
                  "name": "desc1",
                  "fill": "#3D3D3D",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "生米料理の必需品。浸水した生米をなめらかに粉砕できるパワーが必要です。私はVitamixを愛用していますが、他のブランドでも1000W以上のものなら大丈夫。毎日使うものなので、しっかりしたものを選ぶのがおすすめです。",
                  "lineHeight": 1.8,
                  "fontFamily": "Inter",
                  "fontSize": 15,
