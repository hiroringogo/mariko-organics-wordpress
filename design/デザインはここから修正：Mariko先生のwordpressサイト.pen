                    },
                    {
                      "type": "text",
                      "id": "nbJYD",
                      "name": "articleExcerpt",
                      "fill": "#5A5A5A",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "毎日の生米料理に欠かせない、愛用キッチンアイテムをご紹介します。\nどれもAmazonで手軽に購入できるものばかり。ぜひ参考にしてみてくださいね。",
